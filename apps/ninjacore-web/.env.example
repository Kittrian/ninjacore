# Origin of the Rust ninjacore API. Used by the /api/proxy route handler
# (server-side) so the browser never sees the upstream URL or CORS.
# Local dev: point to your laptop's tunnel or direct to Hetzner.
# Production: api.ninjacore.ninjadispute.com (Rust on Hetzner :3018 behind Caddy).
NINJACORE_API_ORIGIN=https://api.ninjacore.ninjadispute.com

# Optional: client-side base for direct fetches (avoid using; prefer /api/proxy).
NEXT_PUBLIC_API_BASE=/api/proxy

# PASETO public key for verifying tokens at the edge.
# Issued by ninja-auth (Ed25519, base64-encoded PEM with literal \n separators).
# AUTH_PASETO_PUBLIC_KEY=

# ─── R2 / S3-compatible storage (read on the BACKEND, not here) ──────────
# These live in the Rust ninjacore env (/etc/ninjacore/env on Hetzner).
# Listed here so the frontend devs know the layout — they don't get loaded
# by Next.js. Backend signs presigned PUT URLs the browser uses directly.
#
# R2_ENDPOINT=https://<account>.r2.cloudflarestorage.com
# R2_BUCKET=clients-docs
# R2_ACCESS_KEY=...
# R2_SECRET_KEY=...
# R2_REGION=auto
# R2_PUBLIC_BASE=https://r2.ninjadispute.com   # Worker URL or public bucket

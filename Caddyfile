{
  # Enable HTTP/3
  http_port 80
  https_port 443
  servers :443 {
    protocol h3
    protocol h2
    protocol h1
  }
}

# Development: Local machine
localhost:3100 {
  reverse_proxy localhost:5173
}

# Production: Domain routing
ninjacore.ninjadispute.com {
  # Enable compression
  encode zstd gzip

  # Security headers
  header X-Content-Type-Options nosniff
  header X-Frame-Options DENY
  header X-XSS-Protection "1; mode=block"
  header Referrer-Policy "strict-origin-when-cross-origin"
  header Strict-Transport-Security "max-age=31536000; includeSubDomains" {
    defer
  }

  # Cache static assets
  @static {
    path /_app/immutable/*
    path /favicon.ico
  }
  header @static Cache-Control "public, max-age=31536000, immutable"

  # Reverse proxy to SvelteKit on localhost:3100
  reverse_proxy localhost:3100 {
    # Keep connections alive
    header_up Connection "upgrade"
    header_up Upgrade "websocket"

    # Forward real IP
    header_up X-Forwarded-For {http.request.remote}
    header_up X-Forwarded-Proto {http.request.scheme}
  }
}

# API proxy (if needed for external API)
api.ninjacore.ninjadispute.com {
  encode zstd gzip

  # Reverse proxy to Rust API
  # Update to Unix socket when available
  reverse_proxy unix//tmp/ninjacore.sock {
    header_up X-Forwarded-For {http.request.remote}
    header_up X-Forwarded-Proto {http.request.scheme}
  }
}

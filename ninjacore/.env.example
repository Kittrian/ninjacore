# ninjacore — main API for ninjacore.ninjadispute.com

# Bind address (Hetzner: 0.0.0.0:8080 behind nginx/Caddy)
BIND_ADDR=0.0.0.0:8080

# SurrealDB connection (matches live Hetzner instance — verified 2026-05-26)
SURREAL_URL=http://127.0.0.1:8000
SURREAL_NS=ninja
SURREAL_DB=dispute
SURREAL_USER=root
SURREAL_PASS=change-me

# Paseto v4 local symmetric key — 32 bytes hex-encoded (64 hex chars)
# Generate: openssl rand -hex 32
PASETO_KEY=

# Optional: log filter (RUST_LOG style)
RUST_LOG=ninjacore=debug,tower_http=info,axum=info

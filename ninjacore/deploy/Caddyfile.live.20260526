ninjacore.ninjadispute.com {
    tls {
        protocols tls1.2 tls1.3
    }
    # Route new Rust-only endpoints to ninjacore :3018.
    @rust_api {
        path /api/uploads/* /api/clients/*/documents/attach
    }
    handle @rust_api {
        reverse_proxy localhost:3018 {
            header_up Host {http.request.host}
            header_up X-Forwarded-For {http.request.remote.host}
            header_up X-Forwarded-Proto {http.request.scheme}
            transport http {
                dial_timeout 5s
                read_timeout 30s
                write_timeout 30s
            }
        }
    }

    reverse_proxy localhost:3017 {
        header_up Host {http.request.host}
        header_up X-Forwarded-For {http.request.remote.host}
        header_up X-Forwarded-Proto {http.request.scheme}
        header_up X-Forwarded-Host {http.request.host}
        
        transport http {
            dial_timeout 5s
            read_timeout 30s
            write_timeout 30s
        }
    }

    log {
        output file /var/log/caddy/ninjacore.log {
            roll_size 100m
            roll_keep 5
        }
        format json
    }

    header / X-Content-Type-Options nosniff
    header / X-Frame-Options DENY
    header / X-XSS-Protection "1; mode=block"
}


BIND_ADDR=0.0.0.0:8090
PUBLIC_BASE_URL=https://api.ninjadispute.com

# Apple Sign In — fill these in from developer.apple.com
APPLE_TEAM_ID=
APPLE_SERVICES_ID=
APPLE_KEY_ID=
APPLE_PRIVATE_KEY_PATH=/etc/ninjadispute/AuthKey_XXXXXXXXXX.p8
# (or inline) APPLE_PRIVATE_KEY_PEM="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"
APPLE_REDIRECT_URI=https://api.ninjadispute.com/auth/apple/callback

FRONTEND_SUCCESS_URL=https://ninjadispute.com/dashboard
FRONTEND_FAILURE_URL=https://ninjadispute.com/login?error=apple
